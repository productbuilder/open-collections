{
  "name": "open-collections",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "pnpm desktop:stage",
    "dev": "pnpm desktop:dev",
    "site:build": "node ./scripts/build-site.mjs",
    "site:preview": "node ./src/desktop/workbench/scripts/dev-static-server.mjs --root ./ --port 4321",
    "desktop:dev": "pnpm --filter @open-collections/workbench-desktop tauri:dev",
    "desktop:build": "pnpm --filter @open-collections/workbench-desktop tauri:build",
    "desktop:info": "pnpm --filter @open-collections/workbench-desktop tauri:info",
    "desktop:stage": "pnpm --filter @open-collections/workbench-desktop stage:frontend",
    "collection-manager:start": "pnpm --filter @open-collections/manager-app start",
    "collection-browser:start": "pnpm --filter @open-collections/browser-app start",
    "configurator:start": "pnpm --filter @open-collections/configurator-app start",
    "bucket-browser:start": "pnpm --filter @open-collections/bucket-browser-app start"
  }
}

