{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open Collections Workbench",
  "version": "0.1.0",
  "identifier": "org.opencollections.workbench",
  "build": {
    "beforeDevCommand": {
      "script": "node ./scripts/dev-static-server.mjs --host 127.0.0.1 --port 1420",
      "cwd": "..",
      "wait": false
    },
    "beforeBuildCommand": {
      "script": "node ./scripts/stage-frontend.mjs",
      "cwd": ".."
    },
    "devUrl": "http://127.0.0.1:1420/src/desktop/workbench/index.html",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Open Collections Workbench",
        "width": 1320,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
